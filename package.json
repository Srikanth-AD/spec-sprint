{
  "name": "spec-sprint",
  "version": "0.1.0",
  "description": "Turn a product spec into sprint-ready engineering tickets with capacity planning. Built for engineering managers.",
  "bin": {
    "spec-sprint": "./dist/index.js"
  },
  "type": "module",
  "license": "MIT",
  "keywords": [
    "engineering-management",
    "sprint-planning",
    "agile",
    "story-points",
    "capacity-planning",
    "jira",
    "linear",
    "product-spec",
    "ai",
    "claude",
    "developer-tools"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "open": "^10.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.3"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  }
}
